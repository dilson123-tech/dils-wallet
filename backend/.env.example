# Aurea Gold / dils-wallet — Backend Env Example
# Safe template only. Do not place real secrets in this file.
# Real values must stay only in local/deploy secret storage.

# ------------------------------------------------------------
# Wallet partner mode
# ------------------------------------------------------------

WALLET_MODE=partner
WALLET_PARTNER_PROVIDER=asaas

# Mandatory safety lock.
# Must remain false during Sandbox validation.
REAL_MONEY_ENABLED=false

# ------------------------------------------------------------
# Asaas Sandbox
# ------------------------------------------------------------

ASAAS_ENV=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Sensitive values.
# Never commit real values.
# Never paste real values in PR, issue, chat, docs or logs.
ASAAS_API_KEY=<DEFINIR_APENAS_NO_ENV_LOCAL_SEGURO>
ASAAS_WEBHOOK_TOKEN=<DEFINIR_APENAS_NO_ENV_LOCAL_SEGURO>

# Optional security allowlist.
# Confirm official source before using.
ASAAS_WEBHOOK_ALLOWED_IPS=<CONFIRMAR_LISTA_OFICIAL_SE_NECESSARIO>

# ------------------------------------------------------------
# Production guard
# ------------------------------------------------------------

# This template is for Sandbox preparation only.
# Do not use production credentials here.
# Do not enable real money here.
